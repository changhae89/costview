{
  "expo": {
    "name": "물가 레이더",
    "slug": "costview",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "costview",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1E3A5F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.costview.app"
    },
    "ios": {
      "bundleIdentifier": "com.costview.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
